# Copier vers .env puis adapter.

# ── Base de données ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/procurement?schema=public"

# ── Auth.js ──  (npx auth secret)
AUTH_SECRET=""
AUTH_URL="http://localhost:3010"

# ── URL publique (liens magiques fournisseurs) ──
APP_URL="http://localhost:3010"

# ── E-mail transactionnel ──
# Dev : Mailpit (host=localhost port=1025). Prod : SMTP de ton fournisseur + SPF/DKIM.
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM="Achats <noreply@example.com>"
